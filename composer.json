{
    "name": "hacmanchester/membership-system",
    "description": "Hackspace Manchester Member System",
    "authors": [
        {
            "name": "Hackspace Manchester",
            "email": "board@hacman.org.uk"
        }
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "fruitcake/laravel-cors": "^2.2",
        "gocardless/gocardless-pro": "^5.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "guzzlehttp/psr7": "^2.0",
        "inertiajs/inertia-laravel": "^0.6.11",
        "intervention/image": "2.*",
        "itsgoingd/clockwork": "^5.0",
        "laracasts/presenter": "~0.2.7",
        "laravel-notification-channels/telegram": "^2.0",
        "laravel/framework": "^9.0",
        "laravel/helpers": "^1.7.2",
        "laravel/tinker": "^2.10.1",
        "michelf/php-markdown": "~1.4",
        "nesbot/carbon": "^2.0.0",
        "owen-it/laravel-auditing": "^12.0",
        "rap2hpoutre/laravel-log-viewer": "^2.4.0",
        "sentry/sentry-laravel": "^4.13.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.8.2",
        "doctrine/dbal": "^3.0",
        "fakerphp/faker": "^1.23",
        "filp/whoops": "~2.17.0",
        "laravel/browser-kit-testing": "^6.4.0",
        "laravel/legacy-factories": "^1.0",
        "larastan/larastan": "^2.0",
        "mockery/mockery": "^1.3.1",
        "nunomaduro/collision": "^6.0",
        "phpunit/phpunit": "^9.3.3",
        "symfony/css-selector": "~6.0",
        "symfony/dom-crawler": "~6.0"
    },
    "autoload": {
        "classmap": [
            "database"
        ],
        "psr-4": {
            "BB\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [],
        "pre-update-cmd": [],
        "post-update-cmd": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-create-project-cmd": [
            "php -r \"copy('.env.example', '.env');\"",
            "@php artisan key:generate --ansi"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true,
            "kylekatarnls/update-helper": true
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    }
}
